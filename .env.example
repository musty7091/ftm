APP_NAME=FTM
APP_ENV=development
APP_DEBUG=true

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=ftm_db
DATABASE_USER=ftm_user
DATABASE_PASSWORD=ftm_password

BACKUP_FOLDER=backups
EXPORT_FOLDER=exports
LOG_FOLDER=logs

# ==================================================
# FTM YEDEKLEME AYARLARI
# ==================================================

BACKUP_ENABLED=true
BACKUP_METHOD=docker
BACKUP_DOCKER_CONTAINER=ftm_postgres
BACKUP_KEEP_DAYS=30

BACKUP_MAIL_ENABLED=false
BACKUP_MAIL_ATTACH_BACKUP=true
BACKUP_MAIL_TO=example1@mail.com,example2@mail.com
BACKUP_MAIL_SUBJECT_PREFIX=FTM

# ==================================================
# FTM MAIL AYARLARI
# ==================================================

MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_TO=

# ==================================================
# FTM GÜVENLİK ÖZET RAPORU MAIL AYARLARI
# ==================================================

SECURITY_SUMMARY_MAIL_ENABLED=false
SECURITY_SUMMARY_MAIL_TO=example1@mail.com,example2@mail.com
SECURITY_SUMMARY_MAIL_SUBJECT_PREFIX=FTM
SECURITY_SUMMARY_PERIOD_HOURS=24

# ==================================================
# FTM SISTEM SAGLIK RAPORU MAIL AYARLARI
# ==================================================

SYSTEM_HEALTH_MAIL_ENABLED=false
SYSTEM_HEALTH_MAIL_TO=example1@mail.com,example2@mail.com
SYSTEM_HEALTH_MAIL_SUBJECT_PREFIX=FTM